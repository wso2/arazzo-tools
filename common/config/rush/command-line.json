{
  "$schema": "https://developer.microsoft.com/json-schemas/rush/v5/command-line.schema.json",
  "commands": [
    {
      "name": "build",
      "commandKind": "bulk",
      "summary": "Build all projects that have changed since they were last built",
      "incremental": true,
      "enableParallelism": true,
      "allowWarningsInSuccessfulBuild": true
    },
    {
      "name": "rebuild",
      "commandKind": "bulk",
      "summary": "Rebuild all projects",
      "incremental": false,
      "enableParallelism": true,
      "allowWarningsInSuccessfulBuild": true
    }
  ],
  "parameters": []
}
