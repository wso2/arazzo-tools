{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "arazzo-extension: watch",
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"group": "watchers"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOrder": "parallel",
		},
		{
			"label": "arazzo-extension: watch-tests",
			"type": "npm",
			"script": "watch-tests",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": "build"
		},
		{
			"label": "arazzo-visualizer",
			"type": "npm",
			"script": "start",
			"path": "../arazzo-designer-visualizer",
			"problemMatcher": "$ts-webpack-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"group": "watchers"
			},
			"group": {
				"kind": "build",
				"isDefault": false
			}
		}
	]
}
